{
  "name": "vite-react-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/finalize-static-build.mjs",
    "preview": "vite preview",
    "lint:css": "stylelint \"src/**/*.css\" --fix --quiet",
    "lint:js": "eslint . --ext ts,tsx --report-unused-disable-directives",
    "lint:types": "tsc --noEmit",
    "check:css-vars": "node scripts/check-css-variables.js",
    "check:css-classes": "node scripts/check-css-classes.js",
    "lint": "bun run lint:types && bun run lint:js && bun run lint:css && bun run check:css-vars && bun run check:css-classes",
    "server": "npm --prefix server install --no-audit --no-fund && npm --prefix server start"
  },
  "devDependencies": {
    "typescript": "~6.0.2",
    "vite": "8.0.14"
  },
  "dependencies": {
    "@blinkdotnew/ui": "^0.5.2",
    "@tanstack/react-query": "5.101.0",
    "@tanstack/react-router": "1.170.11",
    "@tanstack/react-start": "1.168.19",
    "@vitejs/plugin-react": "5.2.0",
    "autoprefixer": "10.4.16",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "postcss": "8.4.31",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "3.4.17",
    "tailwindcss-animate": "^1.0.7"
  }
}
