# Server dependencies & build output
node_modules
dist

# SQLite database files (auto-created on first run; never commit data)
catalog.db
catalog.db-journal
catalog.db-wal
catalog.db-shm
*.db
*.db-journal
*.db-wal
*.db-shm

# Product images + thumbnails (binary data, generated at upload time).
# Keep the folders in git via .gitkeep, ignore the image files.
uploads/products/*
!uploads/products/.gitkeep
uploads/thumbs/*
!uploads/thumbs/.gitkeep

# Logs / env
*.log
.env
.env.local
