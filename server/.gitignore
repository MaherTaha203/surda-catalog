# Server dependencies & build output
node_modules
dist

# SQLite database files (auto-created on first run; never commit data)
catalog.db
catalog.db-journal
catalog.db-wal
catalog.db-shm
*.db
*.db-journal
*.db-wal
*.db-shm

# Downloaded product images (binary data; regenerated by `npm run migrate`).
# Keep the folder in git via .gitkeep, ignore the downloaded files.
uploads/products/*
!uploads/products/.gitkeep

# Logs / env
*.log
.env
.env.local
